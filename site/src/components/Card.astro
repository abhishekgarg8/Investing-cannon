---
// Concept 01 — The Gallery. Full-bleed duotone portrait that flips on hover/tap
// to a cream plaque with the investor's one-line edge and study tags.
import Portrait from './Portrait.astro';
import type { Investor } from '../lib/content';
interface Props { investor: Investor; }
const { investor } = Astro.props;
const { num, slug, name, edge, styleTags, years, hasPortrait } = investor;
const tags = styleTags.slice(0, 4);
---
<a class="card" href={`/investors/${slug}`} aria-label={name}>
  <div class="inner">
    <div class="face front">
      <Portrait num={num} name={name} hasPortrait={hasPortrait} />
      <div class="plate">
        <div class="idx mono">{num}</div>
        <h3 class="serif">{name}</h3>
        {years && <div class="yrs">{years}</div>}
      </div>
    </div>
    <div class="face back">
      <div class="kicker mono">THE EDGE</div>
      {edge && <blockquote class="serif">{edge}</blockquote>}
      <div class="cats">{tags.map((t) => <span>{t}</span>)}</div>
      <div class="go">Enter the study &rarr;</div>
    </div>
  </div>
</a>

<style>
  .card { display: block; perspective: 1600px; aspect-ratio: 3 / 4; cursor: pointer; }
  .inner {
    position: relative; width: 100%; height: 100%;
    transition: transform .85s cubic-bezier(.2,.7,.2,1);
    transform-style: preserve-3d;
  }
  .card:hover .inner, .card:focus-visible .inner, .card.flipped .inner { transform: rotateY(180deg); }

  .face {
    position: absolute; inset: 0; overflow: hidden; border-radius: 14px;
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    box-shadow: 0 1px 0 #e8e2d6, 0 24px 50px -28px rgba(40,30,15,.35);
  }
  .back { transform: rotateY(180deg); }

  /* front plate */
  .plate {
    position: absolute; left: 0; right: 0; bottom: 0; padding: 22px 20px 20px; color: #f4efe6;
    background: linear-gradient(to top, rgba(15,12,8,.9), rgba(15,12,8,.42) 62%, transparent);
  }
  .idx { font-size: 11px; letter-spacing: 3px; opacity: .72; }
  .plate h3 { font-weight: 500; font-size: 25px; margin-top: 4px; line-height: 1.05; }
  .yrs { font-size: 12px; opacity: .65; margin-top: 5px; }

  /* back plaque */
  .back {
    background: var(--paper-2); color: #1c1813;
    padding: 26px 24px; display: flex; flex-direction: column;
  }
  .kicker { font-size: 10px; letter-spacing: 2.5px; color: var(--muted-2); }
  blockquote { font-weight: 500; font-size: 19px; line-height: 1.32; margin-top: 10px; }
  .cats { margin-top: auto; display: flex; flex-wrap: wrap; gap: 6px; }
  .cats span {
    font-size: 11px; color: #6f675a; border: 1px solid #ddd5c6;
    border-radius: 20px; padding: 4px 10px;
  }
  .go { margin-top: 16px; font-size: 12.5px; font-weight: 600; color: var(--accent); letter-spacing: .3px; }

  @media (prefers-reduced-motion: reduce) {
    .inner { transition: none; }
  }
</style>

<script>
  // Tap-to-flip on touch devices (no hover). First tap flips, second follows the link.
  if (window.matchMedia('(hover: none)').matches) {
    document.querySelectorAll('.card').forEach((card) => {
      card.addEventListener('click', (e) => {
        if (!card.classList.contains('flipped')) {
          e.preventDefault();
          document.querySelectorAll('.card.flipped').forEach((c) => c.classList.remove('flipped'));
          card.classList.add('flipped');
        }
      });
    });
  }
</script>
