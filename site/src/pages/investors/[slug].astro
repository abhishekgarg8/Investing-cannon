---
import Base from '../../layouts/Base.astro';
import Portrait from '../../components/Portrait.astro';
import { getInvestors, getInvestor } from '../../lib/content';

export function getStaticPaths() {
  return getInvestors().map((i) => ({ params: { slug: i.slug } }));
}

const { slug } = Astro.params;
const data = getInvestor(slug!);
if (!data) return Astro.redirect('/404');
const { investor, documents } = data;
---
<Base title={`${investor.name} — The Investing Canon`} description={investor.edge}>
  <article class="wrap">
    <a class="back-link mono" href="/">&larr; All investors</a>

    <header class="ihead">
      <div class="ihead-portrait">
        <Portrait num={investor.num} name={investor.name} hasPortrait={investor.hasPortrait} />
      </div>
      <div class="ihead-text">
        <div class="idx mono">{investor.num}</div>
        <h1 class="serif">{investor.name}</h1>
        {investor.years && <div class="yrs">{investor.years}</div>}
        {investor.edge && <p class="edge serif">{investor.edge}</p>}
        <div class="tags">{investor.styleTags.map((t) => <span>{t}</span>)}</div>
      </div>
    </header>

    {documents.length > 0 && (
      <nav class="tabs" aria-label="Documents">
        {documents.map((doc, i) => (
          <button class:list={['tab', { active: i === 0 }]} data-target={doc.file}>{doc.label}</button>
        ))}
      </nav>
    )}

    {documents.map((doc, i) => (
      <section class:list={['doc', 'prose', { active: i === 0 }]} data-doc={doc.file} set:html={doc.html} />
    ))}
  </article>
</Base>

<style>
  article { padding-bottom: 60px; }
  .back-link { display: inline-block; margin: 8px 0 26px; font-size: 12px; letter-spacing: 1px; color: var(--muted); }
  .back-link:hover { color: var(--accent); }

  .ihead { display: flex; gap: 30px; align-items: flex-end; padding-bottom: 30px; border-bottom: 1px solid var(--line); }
  .ihead-portrait {
    position: relative; width: 168px; height: 224px; flex: none;
    border-radius: 12px; overflow: hidden; box-shadow: 0 18px 40px -24px rgba(40,30,15,.4);
  }
  .ihead-text .idx { font-size: 12px; letter-spacing: 3px; color: var(--muted-2); }
  .ihead-text h1 { font-weight: 500; font-size: clamp(32px, 5vw, 50px); letter-spacing: -.8px; line-height: 1.02; margin-top: 6px; }
  .yrs { color: var(--muted); font-size: 14px; margin-top: 8px; }
  .edge { font-size: clamp(17px, 2.4vw, 21px); line-height: 1.4; max-width: 640px; margin-top: 16px; color: #2a2620; }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 18px; }
  .tags span { font-size: 11.5px; color: #6f675a; border: 1px solid var(--line); border-radius: 20px; padding: 4px 11px; }

  @media (max-width: 620px) {
    .ihead { flex-direction: column; align-items: flex-start; gap: 20px; }
    .ihead-portrait { width: 130px; height: 173px; }
  }

  /* tabs */
  .tabs {
    position: sticky; top: 0; z-index: 5; display: flex; gap: 4px; overflow-x: auto;
    padding: 14px 0; margin: 0 0 8px; background: rgba(250,250,250,.92);
    backdrop-filter: blur(8px); border-bottom: 1px solid #ececec;
  }
  .tab {
    flex: none; font: inherit; font-size: 13px; color: var(--muted); cursor: pointer;
    background: none; border: none; padding: 8px 14px; border-radius: 8px; transition: all .18s; white-space: nowrap;
  }
  .tab:hover { color: var(--ink); background: #f0ece3; }
  .tab.active { color: var(--ink); background: #efe8da; font-weight: 600; }

  /* documents */
  .doc { display: none; }
  .doc.active { display: block; animation: fade .35s ease; }
  @keyframes fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
</style>

<!-- Prose styling for rendered markdown (global so set:html content is reached) -->
<style is:global>
  .prose { max-width: 720px; padding-top: 22px; font-size: 16.5px; line-height: 1.72; color: #242019; }
  .prose > *:first-child { margin-top: 0; }
  .prose h2 { font-family: 'Fraunces', serif; font-weight: 500; font-size: 27px; letter-spacing: -.3px; margin: 44px 0 14px; }
  .prose h3 { font-size: 18px; font-weight: 600; margin: 32px 0 10px; }
  .prose h4 { font-size: 15px; font-weight: 600; margin: 24px 0 8px; color: var(--muted); }
  .prose p { margin: 0 0 18px; }
  .prose a { color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(180,69,47,.25); }
  .prose a:hover { border-bottom-color: var(--accent); }
  .prose ul, .prose ol { margin: 0 0 18px; padding-left: 22px; }
  .prose li { margin: 6px 0; }
  .prose blockquote {
    margin: 24px 0; padding: 4px 0 4px 22px; border-left: 3px solid var(--accent);
    font-family: 'Fraunces', serif; font-size: 19px; line-height: 1.45; color: #2a2620;
  }
  .prose hr { border: none; border-top: 1px solid var(--line); margin: 36px 0; }
  .prose code { font-family: 'JetBrains Mono', monospace; font-size: .88em; background: #efeae0; padding: 2px 6px; border-radius: 5px; }
  .prose table { width: 100%; border-collapse: collapse; margin: 22px 0; font-size: 14.5px; display: block; overflow-x: auto; }
  .prose th, .prose td { text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--line); vertical-align: top; }
  .prose th { font-weight: 600; background: #f1ece2; }
  .prose tr:hover td { background: #faf7f0; }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const docs = document.querySelectorAll<HTMLElement>('.doc');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.target;
      tabs.forEach((t) => t.classList.toggle('active', t === tab));
      docs.forEach((d) => d.classList.toggle('active', d.dataset.doc === target));
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
